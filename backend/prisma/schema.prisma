generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TableStatus {
  EMPTY
  RESERVED
  OCCUPIED
  PICKUP_READY
}

enum ReservationStatus {
  PENDING
  SEATED
  CANCELLED
}

enum OrderItemStatus {
  WAITING
  COOKING
  DONE
}

enum HandledBy {
  KITCHEN
  HALL
}

model Table {
  id       String      @id @default(cuid())
  name     String
  x        Float
  y        Float
  width    Float       @default(80)
  height   Float       @default(80)
  status       TableStatus   @default(EMPTY)
  sessions     TableSession[]
  reservations Reservation[]
}

model Reservation {
  id              String            @id @default(cuid())
  guestName       String
  phoneLastDigits String
  partySize       Int
  reservedAt      DateTime
  notes           String?
  tableId         String?
  table           Table?            @relation(fields: [tableId], references: [id])
  status          ReservationStatus @default(PENDING)
  session         TableSession?
  createdAt       DateTime          @default(now())
}

model TableSession {
  id              String       @id @default(cuid())
  tableId         String
  table           Table        @relation(fields: [tableId], references: [id])
  reservationId   String?      @unique
  reservation     Reservation? @relation(fields: [reservationId], references: [id])
  partySize       Int
  phoneLastDigits String?
  notes           String?
  startedAt       DateTime     @default(now())
  closedAt        DateTime?
  orders          Order[]
}

model Order {
  id             String       @id @default(cuid())
  tableSessionId String
  tableSession   TableSession @relation(fields: [tableSessionId], references: [id])
  createdAt      DateTime     @default(now())
  items          OrderItem[]
}

model OrderItem {
  id         String          @id @default(cuid())
  orderId    String
  order      Order           @relation(fields: [orderId], references: [id])
  menuItemId String
  menuItem   MenuItem        @relation(fields: [menuItemId], references: [id])
  quantity   Int
  status     OrderItemStatus @default(WAITING)
  handledBy  HandledBy
  createdAt  DateTime        @default(now())
}

model MenuItem {
  id          String      @id @default(cuid())
  categoryId  String
  category    Category    @relation(fields: [categoryId], references: [id])
  name        String
  price       Int
  handledBy   HandledBy
  isAvailable Boolean     @default(true)
  orderItems  OrderItem[]
}

model Category {
  id        String     @id @default(cuid())
  name      String
  sortOrder Int        @default(0)
  items     MenuItem[]
}

model Settings {
  id       String @id @default("singleton")
  adminPin String @default("0000")
}
